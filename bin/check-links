#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

excludes=()
if [[ "${GITHUB_HEAD_REF:-}" = prepare-release-* ]]; then
  excludes+=(--exclude https://github.com/cerbos/cerbos-sdk-ruby/compare/)
fi

exec docker compose \
  run \
  --interactive \
  --rm \
  lychee \
  --config /input/lychee.toml \
  "${excludes[@]}" \
  .
